{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@filepad/agent-access-sdk": ["packages/agent-access-sdk/src/index.ts"],
      "@filepad/agent-access-sdk/*": ["packages/agent-access-sdk/src/*"],
      "@filepad/agent-connect": ["packages/agent-connect/src/index.ts"],
      "@filepad/agent-connect/*": ["packages/agent-connect/src/*"],
      "@filepad/mcp-server": ["packages/mcp-server/src/index.ts"],
      "@filepad/mcp-server/*": ["packages/mcp-server/src/*"],
      "@filepad/claude-code-hooks": ["packages/claude-code-hooks/src/index.ts"],
      "@filepad/claude-code-hooks/*": ["packages/claude-code-hooks/src/*"],
      "@filepad/guardian": ["packages/guardian/src/index.ts"],
      "@filepad/guardian/*": ["packages/guardian/src/*"],
      "@filepad/runtime-adapter-claude-code": ["packages/runtime-adapter-claude-code/src/index.ts"],
      "@filepad/runtime-adapter-claude-code/*": ["packages/runtime-adapter-claude-code/src/*"]
    }
  }
}
