{
  "name": "@filepad/guardian",
  "version": "0.1.0",
  "description": "Filepad Guardian — local evidence reporter for Active Contracts. Runs checks, captures provenance, reports evidence to Filepad.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "filepad-guardian": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./executor": {
      "types": "./dist/executor.d.ts",
      "default": "./dist/executor.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm -C ../agent-access-sdk build",
    "pretest": "pnpm -C ../agent-access-sdk build",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "pack:check": "node ../../scripts/ci/check-package-pack.mjs"
  },
  "keywords": [
    "filepad",
    "guardian",
    "active-contracts",
    "evidence",
    "agent",
    "accountability"
  ],
  "author": "Filepad <support@filepad.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filepad/agent-access.git",
    "directory": "packages/guardian"
  },
  "bugs": {
    "url": "https://github.com/filepad/agent-access/issues"
  },
  "homepage": "https://github.com/filepad/agent-access#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@filepad/agent-access-sdk": "^0.1.6",
    "chokidar": "^4.0.3",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  }
}
